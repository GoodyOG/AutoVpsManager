#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

mkdir -p /etc/xray/strikes

clear
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}               SECURITY & LOCK MANAGER                ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "  ${GREEN}[1]${NC} View Locked Accounts"
echo -e "  ${GREEN}[2]${NC} Manual Lock User"
echo -e "  ${GREEN}[3]${NC} Unlock User (Resets Strikes)"
echo -e "  ${GREEN}[4]${NC} Reset All User Strikes"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "  ${RED}[0]${NC} Back to SSH Menu"
echo -e ""
read -p " Select Option : " req || exit 1

case $req in
    1)
        clear
        echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
        echo -e "${RED}                 LOCKED ACCOUNTS                      ${NC}"
        echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
        USERS=$(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd)
        locked_count=0
        i=1
        
        for user in $USERS; do
            status=$(passwd -S "$user" 2>/dev/null | awk '{print $2}')
            if [[ "$status" == "L" || "$status" == "LK" ]]; then
                # Print the header only once if locked users are found
                if [[ $locked_count -eq 0 ]]; then
                    echo -e " NO   USER            STRIKES"
                    echo -e "${CYAN}───────────────────────────────────────────────────────${NC}"
                fi
                strikes=0
                [[ -f "/etc/xray/strikes/$user" ]] && strikes=$(cat /etc/xray/strikes/$user)
                printf " %-4s %-15s %-5s\n" "$i." "$user" "$strikes"
                ((locked_count++))
                ((i++))
            fi
        done
        
        if [[ $locked_count -eq 0 ]]; then
            echo -e "  ${GREEN}No accounts are currently locked.${NC}"
        fi
        echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
        read -n 1 -s -r -p "Press any key to return..." || exit 1
        locker
        ;;
    2)
        clear
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${YELLOW}            MANUAL LOCK USER              ${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        tmp_users="/tmp/unlocked_users.txt"
        > "$tmp_users"
        
        USERS=$(awk -F: '$3 >= 1000 && $1 != "nobody" && ($7 == "/bin/false" || $7 == "/usr/sbin/nologin" || $7 == "/bin/true") {print $1}' /etc/passwd)
        for u in $USERS; do
            status=$(passwd -S "$u" 2>/dev/null | awk '{print $2}')
            # If not locked
            if [[ "$status" != "L" && "$status" != "LK" ]]; then
                echo "$u" >> "$tmp_users"
            fi
        done
        
        if [[ ! -s "$tmp_users" ]]; then
            echo -e " ${GREEN}No active (unlocked) users found.${NC}"
            rm -f "$tmp_users"
            read -n 1 -s -r -p "Press any key to return..." || exit 1
            locker
            exit
        fi
        
        echo -e " NO   USER"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        i=1
        while read -r u; do
            printf " %-4s %-15s\n" "$i." "$u"
            ((i++))
        done < "$tmp_users"
        echo -e " 0.   Back to Menu"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        read -p " Select Number or Username : " input || exit 1
        
        if [[ "$input" == "0" || "$input" == "00" ]]; then
            rm -f "$tmp_users"
            locker
            exit
        fi
        
        if grep -q -x "$input" "$tmp_users"; then
            user="$input"
        elif [[ "$input" =~ ^[0-9]+$ ]]; then
            user=$(sed -n "${input}p" "$tmp_users")
        else
            user=""
        fi
        
        if [[ -z "$user" ]]; then
            echo -e "${RED}[ERROR] Invalid selection.${NC}"
            rm -f "$tmp_users"
            sleep 2
            locker
            exit
        fi
        
        passwd -l "$user" > /dev/null 2>&1
        
        # --- AGGRESSIVE DISCONNECT LOGIC ---
        # 1. Force kill all processes owned by the user's UID
        pkill -u "$user" -KILL 2>/dev/null
        killall -9 -u "$user" 2>/dev/null
        
        # 2. Hunt down and terminate active Dropbear threads from the Journal
        logged_pids=$(journalctl -u dropbear --since "1 day ago" | grep "Password auth succeeded for '$user'" | awk '{print $5}' | tr -dc '0-9\n')
        for pid in $logged_pids; do
            kill -9 $pid 2>/dev/null
        done
        echo -e " ${GREEN}[+] User $user has been locked and disconnected!${NC}"
        rm -f "$tmp_users"
        sleep 2
        locker
        ;;
    3)
        clear
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${YELLOW}              UNLOCK USER                 ${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        tmp_users="/tmp/locked_users.txt"
        > "$tmp_users"
        
        USERS=$(awk -F: '$3 >= 1000 && $1 != "nobody" && ($7 == "/bin/false" || $7 == "/usr/sbin/nologin" || $7 == "/bin/true") {print $1}' /etc/passwd)
        for u in $USERS; do
            status=$(passwd -S "$u" 2>/dev/null | awk '{print $2}')
            # If locked
            if [[ "$status" == "L" || "$status" == "LK" ]]; then
                strikes=0
                [[ -f "/etc/xray/strikes/$u" ]] && strikes=$(cat /etc/xray/strikes/$u)
                echo "$u|$strikes" >> "$tmp_users"
            fi
        done
        
        if [[ ! -s "$tmp_users" ]]; then
            echo -e " ${GREEN}No accounts are currently locked.${NC}"
            rm -f "$tmp_users"
            read -n 1 -s -r -p "Press any key to return..." || exit 1
            locker
            exit
        fi
        
        echo -e " NO   USER            STRIKES"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        i=1
        while IFS='|' read -r u s; do
            printf " %-4s %-15s %-5s\n" "$i." "$u" "$s"
            ((i++))
        done < "$tmp_users"
        echo -e " 0.   Back to Menu"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        read -p " Select Number or Username : " input || exit 1
        
        if [[ "$input" == "0" || "$input" == "00" ]]; then
            rm -f "$tmp_users"
            locker
            exit
        fi
        
        if grep -q "^${input}|" "$tmp_users"; then
            user="$input"
        elif [[ "$input" =~ ^[0-9]+$ ]]; then
            user=$(sed -n "${input}p" "$tmp_users" | cut -d'|' -f1)
        else
            user=""
        fi
        
        if [[ -z "$user" ]]; then
            echo -e "${RED}[ERROR] Invalid selection.${NC}"
            rm -f "$tmp_users"
            sleep 2
            locker
            exit
        fi
        
        passwd -u "$user" > /dev/null 2>&1
        rm -f /etc/xray/strikes/"$user"
        echo -e " ${GREEN}[+] User $user unlocked. Strikes reset to 0.${NC}"
        rm -f "$tmp_users"
        sleep 2
        locker
        ;;
    4)
        rm -f /etc/xray/strikes/*
        echo -e "\n ${GREEN}[+] All strike counters have been reset to 0!${NC}"
        sleep 2
        locker
        ;;
    0)
        menu-ssh.sh
        ;;
    *)
        echo -e "${RED}Invalid Option${NC}"
        sleep 1
        locker
        ;;
esac␀
