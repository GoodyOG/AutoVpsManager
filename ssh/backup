#!/bin/bash


# --- Techychi Portable Backup Manager (Event-Driven Edition) ---

TG_CONF="/etc/xray/tg_backup.conf"
BACKUP_DIR="/root/backup_temp" 

# 1. CREDENTIAL CHECKER FUNCTION
check_credentials() {
    if [ ! -f "$TG_CONF" ]; then
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e " \033[0;32m[!] First Time Setup: Telegram Cloud Backup\033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        echo -e " \033[0;33mCRITICAL:\033[0m You MUST press 'Start' on your bot in Telegram"
        echo -e " before it can send you files!\n"
        read -p " Enter Telegram Bot Token : " BOT_TOKEN || exit 1
        read -p " Enter Telegram Chat ID   : " CHAT_ID || exit 1
        
        if [[ -n "$BOT_TOKEN" && -n "$CHAT_ID" ]]; then
            echo "BOT_TOKEN=\"$BOT_TOKEN\"" > $TG_CONF
            echo "CHAT_ID=\"$CHAT_ID\"" >> $TG_CONF
            chmod 600 $TG_CONF
        else
            echo -e " \033[0;31m[ERROR] Token and Chat ID cannot be empty!\033[0m"
            sleep 2
            return 1
        fi
    fi
    return 0
}

# 2. THE CORE BACKUP ENGINE (With Concurrency Lock)
run_backup() {
    local IS_CRON=$1
    
    # CONCURRENCY LOCK: Prevent RAM crashes if multiple users are created at the exact same time
    if [[ -f /tmp/backup_running ]]; then exit 0; fi
    touch /tmp/backup_running
    
    if [[ "$IS_CRON" == "cron" ]]; then
        if [ ! -f "$TG_CONF" ]; then rm -f /tmp/backup_running; exit 0; fi
    else
        check_credentials || { rm -f /tmp/backup_running; backup.sh; exit 1; }
    fi
    
    source $TG_CONF
    
    IP=$(curl -sS -4 ifconfig.me)
    DOMAIN=$(cat /etc/xray/domain 2>/dev/null || echo "No-Domain")
    DATE=$(date +"%Y-%m-%d_%H-%M")
    FILENAME="Backup_${IP}_${DATE}.zip"

    [[ "$IS_CRON" != "cron" ]] && echo -e "\n \033[0;32m[+]\033[0m Compiling portable user & system data..."
    
    rm -rf "$BACKUP_DIR"
    mkdir -p "$BACKUP_DIR"/ssh
    mkdir -p "$BACKUP_DIR"/xray
    mkdir -p "$BACKUP_DIR"/system
    mkdir -p "$BACKUP_DIR"/slowdns

    # Extract Users safely
    awk -F: '$3 >= 1000 && $1 != "nobody" && ($7 == "/bin/false" || $7 == "/usr/sbin/nologin" || $7 == "/bin/true") {print $1}' /etc/passwd > "$BACKUP_DIR"/ssh/vpn_users.txt
    touch "$BACKUP_DIR"/ssh/passwd "$BACKUP_DIR"/ssh/shadow "$BACKUP_DIR"/ssh/group "$BACKUP_DIR"/ssh/gshadow
    
    while read user; do
        grep -w "^$user" /etc/passwd >> "$BACKUP_DIR"/ssh/passwd
        grep -w "^$user" /etc/shadow >> "$BACKUP_DIR"/ssh/shadow
        grep -w "^$user" /etc/group >> "$BACKUP_DIR"/ssh/group
        grep -w "^$user" /etc/gshadow >> "$BACKUP_DIR"/ssh/gshadow
    done < "$BACKUP_DIR"/ssh/vpn_users.txt
    
    # Copy Configs
    cp /usr/local/etc/xray/config.json "$BACKUP_DIR"/xray/config.json
    cp -r /etc/xray/limit "$BACKUP_DIR"/xray/limit 2>/dev/null

    # Copy SlowDNS Keys
    [[ -f /etc/slowdns/server.pub ]] && cp /etc/slowdns/server.pub "$BACKUP_DIR"/slowdns/
    [[ -f /etc/slowdns/server.key ]] && cp /etc/slowdns/server.key "$BACKUP_DIR"/slowdns/

    # Copy System Settings (Cronjobs & Bot Auth)
    [[ -f /etc/xray/tg_backup.conf ]] && cp /etc/xray/tg_backup.conf "$BACKUP_DIR"/system/
    [[ -f /etc/cron.d/auto_backup ]] && cp /etc/cron.d/auto_backup "$BACKUP_DIR"/system/
    [[ -f /etc/cron.d/auto_reboot ]] && cp /etc/cron.d/auto_reboot "$BACKUP_DIR"/system/
    [[ -f /etc/xray/instant_backup ]] && cp /etc/xray/instant_backup "$BACKUP_DIR"/system/
    
    cd "$BACKUP_DIR" || { rm -f /tmp/backup_running; exit; }
    zip -r /root/"$FILENAME" * > /dev/null 2>&1
    cd /root || { rm -f /tmp/backup_running; exit; }
    
    [[ "$IS_CRON" != "cron" ]] && echo -e " \033[0;32m[+]\033[0m Uploading to Google Drive..."
    
    # Push to Google Drive
    rclone copy /root/"$FILENAME" gdrive:/VPS_Backups/
    
    # Generate the raw share link from Google Drive
    RAW_LINK=$(rclone link gdrive:/VPS_Backups/"$FILENAME")
    
    # Instantly convert it to a Direct Download link for Telegram & Terminal
    if [[ "$RAW_LINK" == *"drive.google.com"* ]]; then
        FILE_ID=$(echo "$RAW_LINK" | sed -E 's/.*(\/d\/|id=)([a-zA-Z0-9_-]+).*/\2/')
        if [[ -n "$FILE_ID" && "$FILE_ID" != "$RAW_LINK" ]]; then
            LINK="https://drive.google.com/uc?export=download&id=$FILE_ID"
        else
            LINK="$RAW_LINK"
        fi
    else
        LINK="Google Drive Link Generation Failed"
    fi

    [[ "$IS_CRON" != "cron" ]] && echo -e " \033[0;32m[+]\033[0m Transmitting to Telegram Bot..."

    # HTML formatted payload with proper newlines
    CAPTION=$(echo -e "📦 <b>New VPS Backup</b>\n\n📡 <b>IP:</b> <code>$IP</code> - $DOMAIN\n📅 <b>Date:</b> $DATE\n🔗 <b>Drive Link:</b> $LINK\n\n<i>Thanks for using @TheTechSavageTelegram Autoscript</i>")

    TG_RESPONSE=$(curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendDocument" \
        -F chat_id="$CHAT_ID" \
        -F document=@"/root/$FILENAME" \
        -F caption="$CAPTION" \
        -F parse_mode="HTML")
        
    rm -rf "$BACKUP_DIR"
    rm -f /root/"$FILENAME"
    rm -f /tmp/backup_running
    
    if [[ "$IS_CRON" != "cron" ]]; then
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e " \033[0;32mBACKUP COMPLETED!\033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        echo -e " \033[0;33mDrive Link:\033[0m $LINK"
        
        # Smart Error Handling
        if echo "$TG_RESPONSE" | grep -q '"ok":true'; then
            echo -e " \033[0;33mTelegram Bot:\033[0m \033[0;32mSuccessfully delivered to chat.\033[0m"
        else
            ERR_MSG=$(echo "$TG_RESPONSE" | jq -r .description 2>/dev/null || echo "Unknown API Error")
            echo -e " \033[0;33mTelegram Bot:\033[0m \033[0;31mFAILED - $ERR_MSG\033[0m"
            echo -e " \033[0;31mFix: Ensure you have sent a message to your bot first!\033[0m"
        fi
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        read -n 1 -s -r -p "Press any key to return..." || exit 1
        backup.sh
    fi
}

# 3. CHECK IF TRIGGERED BY BACKGROUND CRON OR EVENT
if [[ "$1" == "cron" ]]; then
    run_backup "cron"
    exit 0
fi

# 4. INTERACTIVE MENU UI
clear
if [ -f /etc/cron.d/auto_backup ]; then
    # Read the hour column from the cronjob
    CRON_FREQ=$(grep "backup.sh" /etc/cron.d/auto_backup | awk '{print $2}')
    
    if [ -f /etc/xray/instant_backup ]; then
        if [[ "$CRON_FREQ" == "*/12" ]]; then
            CRON_STAT="\033[0;32m[ACTIVE] (Instant on New User + 12h)\033[0m"
        else
            CRON_STAT="\033[0;32m[ACTIVE] (Instant on New User + 24h)\033[0m"
        fi
    else
        if [[ "$CRON_FREQ" == "*/12" ]]; then
            CRON_STAT="\033[0;32m[ACTIVE] (Every 12 Hours)\033[0m"
        else
            CRON_STAT="\033[0;32m[ACTIVE] (Every 24 Hours)\033[0m"
        fi
    fi
else
    CRON_STAT="\033[0;31m[OFF]\033[0m"
fi

echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
echo -e "\033[0;33m                SYSTEM BACKUP MANAGER                 \033[0m"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "  Auto-Backup Status: $CRON_STAT"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "    \033[0;32m[01]\033[0m  Run Manual Backup Now"
echo -e "    \033[0;32m[02]\033[0m  Set Auto-Backup (Every 12 Hours)"
echo -e "    \033[0;32m[03]\033[0m  Set Auto-Backup (Every 24 Hours)"
echo -e "    \033[0;32m[04]\033[0m  Set Auto-Backup (Instant on New User + 12h)"
echo -e "    \033[0;32m[05]\033[0m  Set Auto-Backup (Instant on New User + 24h)"
echo -e "    \033[0;32m[06]\033[0m  Turn OFF Auto-Backup"
echo -e "    \033[0;32m[07]\033[0m  Reset Telegram Credentials"
echo -e "    \033[0;32m[08]\033[0m  View Current Telegram Credentials"
echo -e "    \033[0;33m[09]\033[0m  Restore From Backup"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "    \033[0;31m[00]\033[0m  Back to Main Menu"
echo -e ""
read -p " Select menu : " opt || exit 1

case $opt in
    1|01) run_backup "manual" ;;
    2|02) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 */12 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        rm -f /etc/xray/instant_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to every 12 hours (Offset)!\033[0m"
        sleep 2
        backup.sh
        ;;
    3|03) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 0 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        rm -f /etc/xray/instant_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to every 24 hours (12:30 AM)!\033[0m"
        sleep 2
        backup.sh
        ;;
    4|04) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 */12 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        touch /etc/xray/instant_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to Instant on New User + 12h!\033[0m"
        sleep 2
        backup.sh
        ;;
    5|05) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 0 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        touch /etc/xray/instant_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to Instant on New User + 24h!\033[0m"
        sleep 2
        backup.sh
        ;;
    6|06) 
        rm -f /etc/cron.d/auto_backup
        rm -f /etc/xray/instant_backup
        service cron restart
        echo -e " \033[0;31mAuto-Backup turned OFF.\033[0m"
        sleep 2
        backup.sh
        ;;
    7|07)
        rm -f "$TG_CONF"
        echo -e " \033[0;32mCredentials cleared. You will be prompted on next manual backup.\033[0m"
        sleep 2
        backup.sh
        ;;
    8|08)
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e "\033[0;33m             CURRENT TELEGRAM CREDENTIALS             \033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        if [ -f "$TG_CONF" ]; then
            source "$TG_CONF"
            echo -e " \033[0;32mBOT TOKEN:\033[0m $BOT_TOKEN"
            echo -e " \033[0;32mCHAT ID  :\033[0m $CHAT_ID"
        else
            echo -e " \033[0;31m[!] No credentials found. Run a backup to set them up.\033[0m"
        fi
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        read -n 1 -s -r -p "Press any key to return..." || exit 1
        backup.sh
        ;;
    9|09) restore.sh ;;
    0|00) menu ;;
    *) echo "Invalid Option"; sleep 1; backup.sh ;;
esac␀
